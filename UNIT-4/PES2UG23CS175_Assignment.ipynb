    {
      "cell_type": "code",
      "source": [
        "def call_llm(prompt):\n",
        "    response = client.chat.completions.create(\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "        messages=[{\"role\": \"user\", \"content\": prompt}]\n",
        "    )\n",
        "    return response.choices[0].message.content"
      ],
      "metadata": {
        "id": "_3ZNrxbWSyf2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from crewai.tools import tool\n",
        "\n",
        "@tool\n",
        "def rag_tool(question: str) -> dict:\n",
        "    \"\"\"Retrieve relevant documents and generate answer using context.\"\"\"\n",
        "\n",
        "    docs = retriever.invoke(question)   # ✅ FIX HERE\n",
        "    context = \"\\n\".join([d.page_content for d in docs])\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "    Answer the question using ONLY the context below.\n",
        "\n",
        "    Context:\n",
        "    {context}\n",
        "\n",
        "    Question:\n",
        "    {question}\n",
        "    \"\"\"\n",
        "\n",
        "    answer = call_llm(prompt)\n",
        "\n",
        "    return {\n",
        "        \"answer\": answer,\n",
        "        \"context\": context\n",
        "    }"
      ],
      "metadata": {
        "id": "bvQFEugtS1ET"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rag_agent = Agent(\n",
        "    role=\"RAG Retriever\",\n",
        "    goal=\"Retrieve and answer questions using context\",\n",
        "    backstory=\"Expert in retrieving relevant information\",\n",
        "    tools=[rag_tool],\n",
        "    verbose=True\n",
        ")"
      ],
      "metadata": {
        "id": "S-075bweS2mu"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rag_task = Task(\n",
        "    description=\"Answer the user's question and return answer + context\",\n",
        "    agent=rag_agent,\n",
        "    expected_output=\"JSON with answer and context\"\n",
        ")"
      ],
      "metadata": {
        "id": "mLMITQHATdVW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from crewai.tools import BaseTool\n",
        "\n",
        "class EvaluateTool(BaseTool):\n",
        "    name: str = \"evaluate_tool\"\n",
        "    description: str = \"Basic evaluation without OpenAI\"\n",
        "\n",
        "    def _run(self, answer: str, context: str, question: str):\n",
        "\n",
        "        # Simple checks\n",
        "        faithfulness = 1.0 if answer.lower() in context.lower() else 0.5\n",
        "        relevancy = 1.0 if question.lower().split()[0] in answer.lower() else 0.5\n",
        "\n",
        "        verdict = \"PASS\" if faithfulness >= 0.7 and relevancy >= 0.7 else \"FAIL\"\n",
        "\n",
        "        return {\n",
        "            \"faithfulness\": faithfulness,\n",
        "            \"relevancy\": relevancy,\n",
        "            \"verdict\": verdict\n",
        "        }"
      ],
      "metadata": {
        "id": "VdkmASC5TgHv"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "eval_agent = Agent(\n",
        "    role=\"Evaluator\",\n",
        "    goal=\"Evaluate answer quality\",\n",
        "    backstory=\"Expert in evaluating LLM outputs\",\n",
        "    tools=[EvaluateTool()],\n",
        "    verbose=True\n",
        ")"
      ],
      "metadata": {
        "id": "dGz6V7_bThJz"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from crewai.tools import BaseTool\n",
        "\n",
        "class ReviseTool(BaseTool):\n",
        "    name: str = \"revise_tool\"\n",
        "    description: str = \"Improve answer based on feedback and context\"\n",
        "\n",
        "    def _run(self, question: str, answer: str, context: str, feedback: str):\n",
        "\n",
        "        prompt = f\"\"\"\n",
        "        Improve the answer using the given context.\n",
        "\n",
        "        Question: {question}\n",
        "\n",
        "        Bad Answer:\n",
        "        {answer}\n",
        "\n",
        "        Feedback:\n",
        "        {feedback}\n",
        "\n",
        "        Context:\n",
        "        {context}\n",
        "\n",
        "        Give a corrected and improved answer:\n",
        "        \"\"\"\n",
        "\n",
        "        return call_llm(prompt)"
      ],
      "metadata": {
        "id": "bNwfCmTvTuWO"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rev_agent = Agent(\n",
        "    role=\"Revisor\",\n",
        "    goal=\"Fix low-quality answers\",\n",
        "    backstory=\"Expert in refining LLM outputs\",\n",
        "    tools=[ReviseTool()],\n",
        "    verbose=True\n",
        ")"
      ],
      "metadata": {
        "id": "XsOn9DOnUz2r"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def run_pipeline(question):\n",
        "\n",
        "    # STEP 1: RAG\n",
        "    rag_output = rag_tool.run(question)   # ✅ FIX\n",
        "    answer = rag_output[\"answer\"]\n",
        "    context = rag_output[\"context\"]\n",
        "\n",
        "    # STEP 2: EVALUATE\n",
        "    eval_tool_instance = EvaluateTool()\n",
        "    eval_output = eval_tool_instance._run(\n",
        "        answer=answer,\n",
        "        context=context,\n",
        "        question=question\n",
        "    )\n",
        "\n",
        "    if eval_output[\"verdict\"] == \"PASS\":\n",
        "        return {\n",
        "            \"question\": question,\n",
        "            \"initial\": eval_output,\n",
        "            \"final\": eval_output,\n",
        "            \"answer\": answer\n",
        "        }\n",
        "\n",
        "    # STEP 3: REVISE\n",
        "    revise_tool_instance = ReviseTool()\n",
        "    revised_answer = revise_tool_instance._run(\n",
        "        question=question,\n",
        "        answer=answer,\n",
        "        context=context,\n",
        "        feedback=str(eval_output)\n",
        "    )\n",
        "\n",
        "    # STEP 4: RE-EVALUATE\n",
        "    final_eval = eval_tool_instance._run(\n",
        "        answer=revised_answer,\n",
        "        context=context,\n",
        "        question=question\n",
        "    )\n",
        "\n",
        "    return {\n",
        "        \"question\": question,\n",
        "        \"initial\": eval_output,\n",
        "        \"final\": final_eval,\n",
        "        \"answer\": revised_answer\n",
        "    }"
      ],
      "metadata": {
        "id": "9loJ8HILU1LW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "questions = [\n",
        "    \"What is Artificial Intelligence?\",\n",
        "    \"What are the types of AI?\",\n",
        "    \"Explain machine learning.\",\n",
        "    \"Applications of AI?\",\n",
        "    \"History of AI?\",\n",
        "    \"Who invented teleportation?\",          # adversarial\n",
        "    \"Explain black holes in this context?\"  # adversarial\n",
        "]"
      ],
      "metadata": {
        "id": "xF52S5Q9U2Mf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "results = []\n",
        "\n",
        "for q in questions:\n",
        "    print(f\"\\nRunning: {q}\")\n",
        "    res = run_pipeline(q)\n",
        "    results.append(res)"
      ],
      "metadata": {
